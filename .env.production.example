# Reference list of the production runtime variables (compose injects them via
# env_file at runtime; none are baked into the image).
#
# In the automated deploy you do NOT place this file by hand: Ansible renders
# `.env.production` on the server from `ansible/templates/env.production.j2` —
# secrets from the encrypted `ansible/vault.yml`, plus `AUTH_KEYCLOAK_ISSUER` /
# `API_URL` set as plain vars in `ansible/deploy-prod.yml`. This example just
# documents the full set (and is what you'd populate for a manual run).

# --- Keycloak (operator authentication) ---
AUTH_KEYCLOAK_ID=
AUTH_KEYCLOAK_SECRET=
AUTH_KEYCLOAK_ISSUER=        # e.g. https://auth.example.com/realms/city-game

# --- NextAuth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# NOTE: AUTH_URL is intentionally NOT set in production. With multiple tenant
# domains on one container, NextAuth derives the callback URL per-request from
# the traefik-forwarded host (trustHost: true). Each tenant domain's callback
# (https://<domain>/api/auth/callback/keycloak) must be registered as a valid
# redirect URI in the Keycloak client. See docs/adr/0018.

# --- Backend ---
API_URL=                     # backend base URL, e.g. https://api.example.com

# --- Tenant resolution ---
# Do NOT set TENANT_OVERRIDE in production. It is a local-dev-only affordance and
# the backend ignores it; the tenant is resolved from the forwarded host instead.
# See docs/adr/0017-tenant-from-derived-host-not-relayed-origin.md.
