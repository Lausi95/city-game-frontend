# Keep the build context small and never leak local state/secrets into the image.
node_modules
.next
.git
.gitignore
.idea
.opencode
.specify
.claude

# env files — secrets arrive at runtime via env_file, never baked into the image
.env*
!.env.production.example

# build artifacts / local noise
*.tsbuildinfo
npm-debug.log*
.DS_Store
coverage
out
build

# docs & meta not needed at build time
README.md
CONTEXT.md
CLAUDE.md
docs
Dockerfile
.dockerignore
ansible/templates/docker-compose.yml.j2
