# Rendered by Ansible (deploy-prod.yml) from vault secrets + playbook vars.
# DO NOT edit on the server — changes are overwritten on the next deploy.
# Secrets come from ansible/vault.yml; issuer/API_URL are plain playbook vars.

# --- Keycloak (operator authentication) ---
AUTH_KEYCLOAK_ID={{ auth_keycloak_id }}
AUTH_KEYCLOAK_SECRET={{ auth_keycloak_secret }}
AUTH_KEYCLOAK_ISSUER={{ auth_keycloak_issuer }}

# --- NextAuth ---
AUTH_SECRET={{ auth_secret }}
# AUTH_URL is intentionally NOT set — trustHost derives the callback URL from the
# traefik-forwarded host (one container, many tenant domains). See docs/adr/0018.

# --- Backend ---
API_URL={{ api_url }}

# TENANT_OVERRIDE is intentionally unset — prod resolves the tenant from the
# forwarded host (ADR 0017).
